      if (res.ok) {
        const text = await res.text();
        robots = robotsParser(robotsUrl, text);
      } else {
        robots = robotsParser(robotsUrl, "");
      }
      robotsCache.set(origin, robots);
    }

    return robots.isAllowed(targetUrl, userAgent) !== false;
  } catch (err) {
    return true; // fail open
  }
}

